{
    "compilerOptions": {
        "target": "ES5",
        "module": "commonjs",
        "moduleResolution": "node",
        "stripInternal": true,
        "importHelpers": false,
        "strictNullChecks": true,
        "noImplicitAny": false,
        "declaration": true,
        "declarationDir": "bin",
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "types": ["node", "vitest/globals"],
        "lib": ["dom", "es2015", "es5"],
        "outDir":"bin",
    },
    "include": [
        "src/**/*.ts",
        "tests/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
